{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "asan",
            "displayName": "Debug + AddressSanitizer",
            "binaryDir": "build-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "environment": {
                "ASAN_OPTIONS": "detect_stack_use_after_return=1"
            }
        }
    ]
}
